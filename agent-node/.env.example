# ============================================================================
# Hypha Protocol — agent-node configuration template
# Copy to `agent-node/.env` and fill in your own secrets. NEVER commit a real .env.
# ============================================================================

# Server port
PORT=3000

# Stellar network this node targets (testnet | pubnet). Used in the ERC-8004 agentRegistry namespace.
STELLAR_NETWORK=testnet

# --- Secrets (replace the placeholders; do not commit real values) ---

# Stellar secret key of this agent, used for signing txs and the registration ownership proof.
# Generate with: stellar keys generate <name> --network testnet && stellar keys show <name>
AGENT_SECRET_KEY=SA__REPLACE_WITH_YOUR_STELLAR_SECRET_KEY__XXXXXXXXXXXXXXXX

# EVM private key for the XMTP identity (32-byte hex starting with 0x). Generate a fresh random key.
EVM_PRIVATE_KEY=0x__REPLACE_WITH_A_RANDOM_32_BYTE_HEX_KEY__

# --- Payments (x402) ---

# Address that receives x402 USDC payments.
PAYMENT_RECIPIENT_ADDRESS=G__REPLACE_WITH_YOUR_STELLAR_PUBLIC_KEY__

# x402 facilitator / relayer (OpenZeppelin Channel Facilitator).
FACILITATOR_URL=https://channels.openzeppelin.com/x402/testnet

# --- ERC-8004 registry contract IDs (live testnet deployment; see deployments/testnet.json) ---
# REGISTRY_CONTRACT_ID is still read as a fallback for IDENTITY_CONTRACT_ID.
IDENTITY_CONTRACT_ID=CD3TC336MBPL2X2YR22NZTAFHLUHA5JI6EH2KLLYVASJ6JFIP5JOKYLQ
REPUTATION_CONTRACT_ID=CBNLRDIK5Y4TN4W7ILCM2YM7ZY4P5B2ZSS2KBMWDIQNKPNECMGS4TDYD
VALIDATION_CONTRACT_ID=CDZQEANEGUQBWF3RNS32V2ZZKU4ZT7O6UDIFJ26DH7ZH4LR2HT2CCF7L
STAKING_CONTRACT_ID=CBOFX67FJSNNTRVZ7RP37B7FYVIQU7B5GXJRVQ3FKJSJXZNLKC6K5KPG

# This node's on-chain numeric agentId (assigned by the Identity Registry on register()).
AGENT_ID=1

# Public URL of this agent node (used in agent-card / registration file / federation responses).
AGENT_PUBLIC_URL=http://localhost:3000

# SEP-0002 federation name for this agent.
FEDERATION_NAME=oracle*hypha.network
